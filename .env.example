# =============================================
# GOOGLE OAUTH — Tạo tại Google Cloud Console
# =============================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================
# NEXTAUTH
# =============================================
# Tạo secret ngẫu nhiên: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-string
# URL của ứng dụng (thay bằng domain thực khi deploy)
NEXTAUTH_URL=http://localhost:3000

# =============================================
# WHITELIST EMAIL — ai được phép vào LMS
# =============================================
# Nhiều email thì cách nhau bằng dấu phẩy, không có khoảng trắng
ALLOWED_EMAILS=ducnb17@gmail.com,jinlowest@gmail.com

# =============================================
# GOOGLE DRIVE
# =============================================
# ID của thư mục gốc chứa các khóa học trên Google Drive
# Lấy từ URL: https://drive.google.com/drive/folders/FOLDER_ID_Ở_ĐÂY
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-google-drive-root-folder-id
